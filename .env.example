# Salesforce Marketing Cloud - OAuth2 Client Credentials
SFMC_CLIENT_ID=your_client_id_here
SFMC_CLIENT_SECRET=your_client_secret_here

# Account subdomain (e.g. if your auth URL is https://XXXX.auth.marketingcloudapis.com, use XXXX)
SFMC_SUBDOMAIN=your_subdomain_here

# Optional: specific MID for child Business Units (leave blank for parent BU)
SFMC_ACCOUNT_ID=
